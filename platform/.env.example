# GCP Configuration
GCP_PROJECT_ID=billparser-dev
STORAGE_BUCKET=billparser-uploads

# Optional: Firestore collection prefix for multi-tenant isolation
FIRESTORE_PREFIX=

# OCR Provider Keys
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# Normalization: gemini (default from Settings) or mistral — env overrides Settings
NORMALIZE_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Local dev — in-memory DB + file storage (no GCP)
LOCAL_DEV=true

# Optional: buyer GSTINs to never treat as vendor (comma-separated)
# BUYER_GSTIN_BLOCKLIST=27AALCC8489R1ZD

# Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production
ADMIN_EMAIL=admin@praya.io
ADMIN_PASSWORD=admin123

# Server
PORT=4000
NODE_ENV=development
