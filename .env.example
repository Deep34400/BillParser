# --- core ---
DATABASE_URL=postgresql://invoice:invoice@localhost:5432/invoice?schema=public
APP_SECRET=change-me-to-a-long-random-string
UPLOAD_DIR=./uploads
PORT=4000
# --- selection seeds (optional; DB wins after first boot) ---
# Defaults are fully local (Ollama). Switch to a hosted provider here or in the Settings UI.
EXTRACTION_PROVIDER=ollama
STRUCTURING_MODEL_PROVIDER=ollama
STRUCTURING_MODEL=qwen2.5:3b
# --- local Ollama connection (seeds the ollama provider credentials) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=glm-ocr
# --- provider credential seeds (optional) ---
MISTRAL_API_KEY=
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
LLAMAPARSE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# web
VITE_API_BASE=http://localhost:4000
